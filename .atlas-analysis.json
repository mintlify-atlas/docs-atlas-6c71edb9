  "keyFeatures": [
    "API key authentication with Redis backing",
    "Per-key rate limiting with atomic Redis operations",
    "Weighted load balancing across multiple backends",
    "Method-based routing for specific RPC calls",
    "WebSocket proxying with full auth support",
    "Background health checks with automatic failover",
    "Prometheus metrics and Grafana dashboards",
    "Hot configuration reload via SIGHUP"
  ],
  "publicApiSurface": [
    "POST / - Proxy JSON-RPC requests",
    "GET / (WebSocket) - WebSocket proxy on main port",
    "GET /health - Backend health status",
    "GET /metrics - Prometheus metrics",
    "rpc-admin create - Create API key",
    "rpc-admin list - List all API keys",
    "rpc-admin inspect - Inspect API key details",
    "rpc-admin revoke - Revoke API key",
    "rpc-admin update - Update API key settings"
  ]
